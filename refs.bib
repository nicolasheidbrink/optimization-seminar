@article{levy_tunneling_1985,
	title = {The {Tunneling} {Algorithm} for the {Global} {Minimization} of {Functions}},
	volume = {6},
	issn = {0196-5204},
	url = {https://epubs.siam.org/doi/10.1137/0906002},
	doi = {10.1137/0906002},
	abstract = {This paper develops a novel method—the global descent method—for solving a general class of global optimization problems. This method moves from one local minimizer of the objective function f to a better one at each iteration with the help of an auxiliary function termed the global descent function. The global descent function is not only guaranteed to have a local minimizer 𝑥′ over the problem domain in ℝ𝑛 but also ensures that each of its local minimizers is located in some neighborhoods of a better minimizer of f with 𝑓⁡(𝑥′) {\textless}𝑓⁡(𝑥∗). These features of the global descent function enable a global descent to be achieved at each iteration using only local descent methods. Computational experiments conducted on several test problems with up to 1000 variables demonstrate the applicability of the proposed method. Furthermore, numerical comparison experiments carried out with GAMS/BARON on several test problems also justify the efficiency and effectiveness of the proposed method.},
	number = {1},
	urldate = {2026-05-01},
	journal = {SIAM Journal on Scientific and Statistical Computing},
	publisher = {Society for Industrial and Applied Mathematics},
	author = {Levy, A. V. and Montalvo, A.},
	month = jan,
	year = {1985},
	pages = {15--29},
}
